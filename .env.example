# Copy to .env and fill in. runpod-flash auto-loads .env.

# --- RunPod (for LIVE GPU runs; or use `flash login`) ---
# RUNPOD_API_KEY=your_runpod_api_key

# --- Bright Data (for live web ingestion; omit to stay in MOCK) ---
# Web Unlocker / SERP proxy URL. Format:
#   http://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:33335
# BRIGHTDATA_PROXY=http://brd-customer-XXXX-zone-web_unlocker:PASS@brd.superproxy.io:33335
# Optional separate SERP zone proxy for image search (defaults to BRIGHTDATA_PROXY):
# BRIGHTDATA_SERP_PROXY=http://brd-customer-XXXX-zone-serp:PASS@brd.superproxy.io:33335
# Force MOCK scraping even if a proxy is set:
# WALL_BRIGHTDATA_MOCK=1

# --- Demo knobs (all optional; see config.py) ---
# WALL_MOCK=0
# WALL_CONCEPT=sks dog
# WALL_PUBLIC_URL=https://your-tunnel.trycloudflare.com
# WALL_COST_PER_WORKER_SEC=0.00044
